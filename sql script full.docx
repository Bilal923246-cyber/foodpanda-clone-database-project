-- ============================================================
-- FOODPANDA CLONE – FULLY HARDCODED (NO LOOPS)
-- 10 CUSTOMERS | 10 RIDERS | 10 RESTAURANTS | 10 ORDERS
-- All INSERT statements are explicit – easy to explain
-- Author: H.M.Bilal (FA-2025-SEC-B-048)
-- ============================================================

CREATE DATABASE FoodPandaClone_Hardcoded;
GO

USE FoodPandaClone_Hardcoded;
GO

-- ============================================================
-- CREATE 22 TABLES (same structure, fully normalized)
-- ============================================================

CREATE TABLE User_Accounts (
    user_id INT IDENTITY PRIMARY KEY,
    email NVARCHAR(100) UNIQUE NOT NULL,
    password_hash NVARCHAR(255) NOT NULL,
    phone_number NVARCHAR(20),
    user_type NVARCHAR(20) CHECK (user_type IN ('customer','owner','rider','admin')),
    is_active BIT DEFAULT 1,
    created_at DATETIME2 DEFAULT GETDATE()
);

CREATE TABLE Customers (
    customer_id INT IDENTITY PRIMARY KEY,
    user_id INT UNIQUE FOREIGN KEY REFERENCES User_Accounts(user_id) ON DELETE CASCADE,
    first_name NVARCHAR(50),
    last_name NVARCHAR(50),
    loyalty_points INT DEFAULT 0
);

CREATE TABLE Restaurant_Owners (
    owner_id INT IDENTITY PRIMARY KEY,
    user_id INT UNIQUE FOREIGN KEY REFERENCES User_Accounts(user_id) ON DELETE CASCADE,
    first_name NVARCHAR(50),
    last_name NVARCHAR(50),
    business_license NVARCHAR(50)
);

CREATE TABLE Riders (
    rider_id INT IDENTITY PRIMARY KEY,
    user_id INT UNIQUE FOREIGN KEY REFERENCES User_Accounts(user_id) ON DELETE CASCADE,
    first_name NVARCHAR(50),
    last_name NVARCHAR(50),
    vehicle_type NVARCHAR(30),
    license_plate NVARCHAR(15),
    is_available BIT DEFAULT 1,
    rating DECIMAL(3,2) DEFAULT 5.0 CHECK (rating BETWEEN 0 AND 5)
);

CREATE TABLE Addresses (
    address_id INT IDENTITY PRIMARY KEY,
    user_id INT FOREIGN KEY REFERENCES User_Accounts(user_id),
    restaurant_id INT NULL,
    address_line NVARCHAR(255),
    city NVARCHAR(50),
    latitude DECIMAL(10,8),
    longitude DECIMAL(11,8),
    CHECK (user_id IS NOT NULL OR restaurant_id IS NOT NULL)
);

CREATE TABLE Restaurants (
    restaurant_id INT IDENTITY PRIMARY KEY,
    owner_id INT FOREIGN KEY REFERENCES Restaurant_Owners(owner_id),
    name NVARCHAR(100) NOT NULL,
    cuisine_type NVARCHAR(50),
    min_order_amount DECIMAL(10,2),
    delivery_fee DECIMAL(10,2),
    is_open BIT DEFAULT 1
);

CREATE TABLE Menu_Items (
    item_id INT IDENTITY PRIMARY KEY,
    restaurant_id INT FOREIGN KEY REFERENCES Restaurants(restaurant_id) ON DELETE CASCADE,
    name NVARCHAR(100),
    price DECIMAL(10,2),
    category NVARCHAR(50),
    is_available BIT DEFAULT 1
);

CREATE TABLE Orders (
    order_id INT IDENTITY PRIMARY KEY,
    customer_id INT FOREIGN KEY REFERENCES Customers(customer_id),
    restaurant_id INT FOREIGN KEY REFERENCES Restaurants(restaurant_id),
    address_id INT FOREIGN KEY REFERENCES Addresses(address_id),
    status NVARCHAR(20) DEFAULT 'Pending' CHECK (status IN ('Pending','Preparing','OutForDelivery','Delivered','Cancelled')),
    order_date DATETIME2 DEFAULT GETDATE(),
    total_amount DECIMAL(10,2)
);

CREATE TABLE Order_Items (
    order_item_id INT IDENTITY PRIMARY KEY,
    order_id INT FOREIGN KEY REFERENCES Orders(order_id) ON DELETE CASCADE,
    item_id INT FOREIGN KEY REFERENCES Menu_Items(item_id),
    quantity INT CHECK (quantity > 0),
    unit_price DECIMAL(10,2),
    subtotal DECIMAL(10,2)
);

CREATE TABLE Payments (
    payment_id INT IDENTITY PRIMARY KEY,
    order_id INT UNIQUE FOREIGN KEY REFERENCES Orders(order_id),
    amount DECIMAL(10,2),
    payment_method NVARCHAR(30),
    status NVARCHAR(20) DEFAULT 'Completed'
);

CREATE TABLE Delivery_Assignments (
    assignment_id INT IDENTITY PRIMARY KEY,
    order_id INT UNIQUE FOREIGN KEY REFERENCES Orders(order_id),
    rider_id INT FOREIGN KEY REFERENCES Riders(rider_id),
    assigned_at DATETIME2 DEFAULT GETDATE(),
    delivered_at DATETIME2 NULL,
    delivery_status NVARCHAR(20) DEFAULT 'Assigned'
);

CREATE TABLE Reviews (
    review_id INT IDENTITY PRIMARY KEY,
    order_id INT UNIQUE FOREIGN KEY REFERENCES Orders(order_id),
    customer_id INT FOREIGN KEY REFERENCES Customers(customer_id),
    restaurant_rating INT CHECK (restaurant_rating BETWEEN 1 AND 5),
    rider_rating INT CHECK (rider_rating BETWEEN 1 AND 5),
    comment NVARCHAR(500)
);

-- Additional tables (minimal)
CREATE TABLE Promotions (promo_id INT IDENTITY PRIMARY KEY, code NVARCHAR(50) UNIQUE);
CREATE TABLE Kitchen_Staff (staff_id INT IDENTITY PRIMARY KEY, restaurant_id INT FOREIGN KEY REFERENCES Restaurants(restaurant_id));
CREATE TABLE Inventory (inventory_id INT IDENTITY PRIMARY KEY, restaurant_id INT FOREIGN KEY REFERENCES Restaurants(restaurant_id));
CREATE TABLE Support_Tickets (ticket_id INT IDENTITY PRIMARY KEY, user_id INT FOREIGN KEY REFERENCES User_Accounts(user_id));
CREATE TABLE Refunds (refund_id INT IDENTITY PRIMARY KEY, order_id INT FOREIGN KEY REFERENCES Orders(order_id));
CREATE TABLE Seller_Wallet (wallet_id INT IDENTITY PRIMARY KEY, owner_id INT FOREIGN KEY REFERENCES Restaurant_Owners(owner_id));
CREATE TABLE Heatmap_Logs (log_id INT IDENTITY PRIMARY KEY, customer_id INT FOREIGN KEY REFERENCES Customers(customer_id));
CREATE TABLE System_Health (health_id INT IDENTITY PRIMARY KEY);
CREATE TABLE Grocery_Items (grocery_id INT IDENTITY PRIMARY KEY, restaurant_id INT FOREIGN KEY REFERENCES Restaurants(restaurant_id));
CREATE TABLE User_Security (security_id INT IDENTITY PRIMARY KEY, user_id INT FOREIGN KEY REFERENCES User_Accounts(user_id));

