-- ============================================================
-- SIMPLE QUERIES (no window functions, no pagination, no running totals)
-- ============================================================

PRINT '========== 1. BASIC COUNTS ==========';
SELECT 'Total Customers' AS Metric, COUNT(*) AS Value FROM Customers
UNION ALL SELECT 'Total Riders', COUNT(*) FROM Riders
UNION ALL SELECT 'Total Restaurants', COUNT(*) FROM Restaurants
UNION ALL SELECT 'Total Orders', COUNT(*) FROM Orders;

PRINT '========== 2. ORDER STATUS DISTRIBUTION ==========';
SELECT status, COUNT(*) AS order_count FROM Orders GROUP BY status ORDER BY order_count DESC;

PRINT '========== 3. TOTAL REVENUE & AVERAGE ORDER VALUE ==========';
SELECT SUM(total_amount) AS total_revenue, AVG(total_amount) AS avg_order_value
FROM Orders WHERE status = 'Delivered';

PRINT '========== 4. TOP 5 RESTAURANTS BY REVENUE ==========';
SELECT TOP 5 r.name, SUM(o.total_amount) AS revenue
FROM Orders o JOIN Restaurants r ON o.restaurant_id = r.restaurant_id
WHERE o.status = 'Delivered'
GROUP BY r.name ORDER BY revenue DESC;

PRINT '========== 5. TOP 5 CUSTOMERS BY TOTAL SPENT ==========';
SELECT TOP 5 c.first_name, SUM(o.total_amount) AS total_spent
FROM Customers c JOIN Orders o ON c.customer_id = o.customer_id
WHERE o.status = 'Delivered'
GROUP BY c.first_name ORDER BY total_spent DESC;

PRINT '========== 6. RIDER DELIVERY COUNT ==========';
SELECT r.first_name, COUNT(da.assignment_id) AS deliveries
FROM Riders r LEFT JOIN Delivery_Assignments da ON r.rider_id = da.rider_id AND da.delivery_status = 'Delivered'
GROUP BY r.first_name ORDER BY deliveries DESC;

PRINT '========== 7. AVERAGE DELIVERY TIME PER RIDER (minutes) ==========';
SELECT r.first_name, AVG(DATEDIFF(MINUTE, da.assigned_at, da.delivered_at)) AS avg_minutes
FROM Delivery_Assignments da JOIN Riders r ON da.rider_id = r.rider_id
WHERE da.delivered_at IS NOT NULL
GROUP BY r.first_name ORDER BY avg_minutes;

PRINT '========== 8. MOST POPULAR MENU ITEMS ==========';
SELECT TOP 5 mi.name, COUNT(oi.order_item_id) AS times_ordered
FROM Order_Items oi JOIN Menu_Items mi ON oi.item_id = mi.item_id
GROUP BY mi.name ORDER BY times_ordered DESC;

PRINT '========== 9. REVENUE PER CUISINE TYPE ==========';
SELECT r.cuisine_type, SUM(o.total_amount) AS revenue
FROM Orders o JOIN Restaurants r ON o.restaurant_id = r.restaurant_id
WHERE o.status = 'Delivered'
GROUP BY r.cuisine_type ORDER BY revenue DESC;

PRINT '========== 10. MONTHLY REVENUE (LAST 6 MONTHS) ==========';
SELECT FORMAT(order_date, 'yyyy-MM') AS month, SUM(total_amount) AS revenue
FROM Orders WHERE status = 'Delivered'
GROUP BY FORMAT(order_date, 'yyyy-MM')
ORDER BY month DESC;

PRINT '========== 11. CUSTOMERS WHO SPENT MORE THAN AVERAGE ==========';
SELECT c.first_name, SUM(o.total_amount) AS total_spent
FROM Customers c JOIN Orders o ON c.customer_id = o.customer_id
WHERE o.status = 'Delivered'
GROUP BY c.first_name
HAVING SUM(o.total_amount) > (SELECT AVG(total_amount) FROM Orders WHERE status = 'Delivered');

PRINT '========== 12. ORDERS IN LAST 30 DAYS ==========';
SELECT COUNT(*) AS orders_last_30days FROM Orders WHERE order_date >= DATEADD(DAY, -30, GETDATE());

PRINT '========== 13. REVENUE IN LAST 7 DAYS ==========';
SELECT SUM(total_amount) AS revenue_last_7days FROM Orders WHERE status = 'Delivered' AND order_date >= DATEADD(DAY, -7, GETDATE());

PRINT '========== 14. RIDERS WITH HIGHEST AVERAGE CUSTOMER RATING ==========';
SELECT TOP 3 r.first_name, AVG(rev.rider_rating) AS avg_rating
FROM Reviews rev
JOIN Delivery_Assignments da ON rev.order_id = da.order_id
JOIN Riders r ON da.rider_id = r.rider_id
GROUP BY r.first_name ORDER BY avg_rating DESC;

PRINT '========== 15. ALL OutForDelivery ORDERS WITH RIDER NAME ==========';
SELECT o.order_id, r.first_name AS rider, o.total_amount
FROM Orders o
JOIN Delivery_Assignments da ON o.order_id = da.order_id
JOIN Riders r ON da.rider_id = r.rider_id
WHERE o.status = 'OutForDelivery';

PRINT '========== 16. HIGHEST RATED RESTAURANT (min 2 reviews) ==========';
SELECT TOP 1 r.name, AVG(rev.restaurant_rating) AS avg_rating, COUNT(rev.review_id) AS review_count
FROM Reviews rev
JOIN Orders o ON rev.order_id = o.order_id
JOIN Restaurants r ON o.restaurant_id = r.restaurant_id
GROUP BY r.name
HAVING COUNT(rev.review_id) >= 2
ORDER BY avg_rating DESC;

PRINT '========== 17. UPDATE RIDER RATING (example) ==========';
UPDATE Riders SET rating = 4.9 WHERE rider_id = 1;
SELECT 'Rider 1 rating updated to 4.9' AS Message;

PRINT '========== 18. DELETE CUSTOMERS WITH NO ORDERS (if any) ==========';
DELETE FROM Customers WHERE customer_id NOT IN (SELECT customer_id FROM Orders);
SELECT 'Customers with no orders deleted (if any)' AS Message;

PRINT '========== 19. SHOW ORDERS WITH CUSTOMER, RESTAURANT, AND RIDER NAMES ==========';
SELECT TOP 20 o.order_id, c.first_name AS customer, r.name AS restaurant, rd.first_name AS rider, o.status, o.order_date
FROM Orders o
JOIN Customers c ON o.customer_id = c.customer_id
JOIN Restaurants r ON o.restaurant_id = r.restaurant_id
LEFT JOIN Delivery_Assignments da ON o.order_id = da.order_id
LEFT JOIN Riders rd ON da.rider_id = rd.rider_id
ORDER BY o.order_date DESC;

PRINT '========== 20. ORDERS DELIVERED IN LESS THAN 30 MINUTES ==========';
SELECT o.order_id, DATEDIFF(MINUTE, da.assigned_at, da.delivered_at) AS delivery_minutes
FROM Orders o
JOIN Delivery_Assignments da ON o.order_id = da.order_id
WHERE da.delivered_at IS NOT NULL AND DATEDIFF(MINUTE, da.assigned_at, da.delivered_at) < 30;

PRINT '========== END OF SCRIPT ==========';